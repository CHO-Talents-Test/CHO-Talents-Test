# Copy this file to .env.local and fill in secrets locally.
# .env.local is ignored by git.

# GitHub source management
GITHUB_OWNER=CHO-Talents
GITHUB_REPO=CHO-Talents
GITHUB_BRANCH=develop
GITHUB_PAT=

# Supabase public browser config
APP_CONFIG_ENV=production
SUPABASE_PROJECT_REF=blitrrcdkkkszvgylnus
SUPABASE_URL=https://blitrrcdkkkszvgylnus.supabase.co
SUPABASE_ANON_KEY=sb_publishable_TgsQePzjxca9Hr3Lh_dHvA_O1JqRAQ6
SUPABASE_AUTH_EMAIL_DOMAIN=@cho-talents.app

# Supabase management / admin automation
# The access token can be used by Supabase CLI/Management API.
SUPABASE_ACCESS_TOKEN=

# Required only for unrestricted database CRUD or SQL automation.
# Never expose these values to browser code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_CONNECTION_STRING=

# Browser-safe Kakao JavaScript key
KAKAO_MAP_KEY=0ef8925b28135eeac474bc411c456170

# Slack Edge Function secrets
# Store real webhook URLs in Supabase Edge Function secrets, not in browser JS.
SLACK_WEBHOOK_PART1=
